{
  "version": 2,
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 10,
      "runtime": "nodejs22.x",
      "env": {
        "MONGO_URI": "@mongo_uri",
        "JWT_SECRET": "@jwt_secret",
        "UPLOAD_DIR": "/tmp/uploads",
        "PUBLIC_BACKEND_URL": "https://<your-vercel-backend>.vercel.app"
      }
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" }
  ]
}
